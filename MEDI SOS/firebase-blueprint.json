{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "EmergencyContact": {
      "title": "Emergency Contact",
      "description": "Contacts to be alerted during an SOS.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["name", "phoneNumber", "userId"]
    },
    "EmergencyAlert": {
      "title": "Emergency Alert",
      "description": "Active SOS alert data.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "resolved"] },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "latitude", "longitude", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores user profiles."
    },
    "/users/{userId}/contacts/{contactId}": {
      "schema": "EmergencyContact",
      "description": "Managed contacts for a user."
    },
    "/alerts/{alertId}": {
      "schema": "EmergencyAlert",
      "description": "Live emergency alerts."
    }
  }
}
